  "keyFeatures": [
    "PIN-gated app access with configurable expiry (never or duration-based)",
    "Interstitial ad serving with image loading via HttpURLConnection (zero dependencies)",
    "Device-bound PIN verification using Android ID",
    "MT Manager / smali injection support for patched APK use cases",
    "Express.js backend with Prisma ORM and PostgreSQL for impression/click tracking",
    "Next.js admin panel for managing API keys, ads, PIN configuration, and user devices",
    "Programmatic UI with Canvas-drawn icons — no external UI libraries required",
    "Community links dialog (Telegram channels/groups) with JoinDialog"
  ],
  "publicApiSurface": [
